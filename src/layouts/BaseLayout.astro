---
import '../styles/global.css'
import type { Locale } from '@/i18n/config'
import { localizePath } from '@/i18n/paths'
import { strings } from '@/i18n/strings'
import LanguageSwitcher from '@/components/LanguageSwitcher.astro'

interface Props {
  locale: Locale
  pathKey: '/' | '/about' | '/quickstart'
  title: string
  description?: string
}

const { locale, pathKey, title, description } = Astro.props
const tr = strings[locale]
const desc = description ?? tr.meta.siteDescription
const p = (path: string) => localizePath(locale, path)
---

<!doctype html>
<html lang={tr.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={desc} />
    <title>{title} — A2AL</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <nav class="fixed top-0 left-0 right-0 z-50 border-b border-border bg-background/80 backdrop-blur-sm">
      <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between gap-4">
        <a href={p('/')} class="text-accent hover:opacity-80 transition-opacity shrink-0 flex items-center" aria-label="A2AL Home">
          <svg class="h-6 w-auto" viewBox="0 0 120 28" fill="none" stroke="currentColor" stroke-width="6" stroke-linecap="butt" stroke-linejoin="bevel" xmlns="http://www.w3.org/2000/svg">
            <g transform="translate(12, 3) skewX(-14)">
              <!-- A -->
              <polyline points="0,22 10,0 20,22" />
              <line x1="4.5" y1="13" x2="15.5" y2="13" />
              <!-- 2 -->
              <polyline points="28,7 28,0 44,0 44,11 28,22 44,22" />
              <!-- A -->
              <polyline points="52,22 62,0 72,22" />
              <line x1="56.5" y1="13" x2="67.5" y2="13" />
              <!-- L -->
              <polyline points="80,0 80,22 94,22" />
            </g>
          </svg>
        </a>
        <div class="hidden md:flex items-center gap-6">
          <a href={p('/quickstart')} class="text-text-secondary hover:text-white text-sm transition-colors">{tr.nav.quickstart}</a>
          <a href="/docs/integration/overview" class="text-text-secondary hover:text-white text-sm transition-colors">{tr.nav.docs}</a>
          <a href={p('/about')} class="text-text-secondary hover:text-white text-sm transition-colors">{tr.nav.about}</a>
          <LanguageSwitcher locale={locale} pathKey={pathKey} />
          <a
            href="https://github.com/a2al/a2al"
            target="_blank"
            rel="noopener"
            class="text-text-secondary hover:text-white text-sm transition-colors"
          >
            {tr.nav.github}
          </a>
        </div>
        <div class="flex md:hidden items-center gap-2">
          <LanguageSwitcher locale={locale} pathKey={pathKey} />
        </div>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="border-t border-border mt-32">
      <div class="max-w-6xl mx-auto px-6 py-12 flex flex-col md:flex-row justify-between items-start gap-8">
        <div>
          <div class="text-white font-semibold mb-2">A2AL</div>
          <div class="text-text-secondary text-sm">{tr.footer.tagline}</div>
          <div class="text-text-secondary text-sm mt-1">
            {tr.footer.tangled}{' '}
            <a href="https://tanglednet.org" class="hover:text-accent transition-colors">Tangled Network</a>.
          </div>
        </div>
        <div class="flex gap-12 text-sm">
          <div class="flex flex-col gap-3">
            <div class="text-white font-medium">{tr.footer.resources}</div>
            <a href={p('/quickstart')} class="text-text-secondary hover:text-white transition-colors">{tr.footer.quickstart}</a>
            <a href="/docs/integration/overview" class="text-text-secondary hover:text-white transition-colors">{tr.footer.docs}</a>
            <a href="/llms.txt" class="text-text-secondary hover:text-white transition-colors">{tr.footer.llms}</a>
          </div>
          <div class="flex flex-col gap-3">
            <div class="text-white font-medium">{tr.footer.project}</div>
            <a href={p('/about')} class="text-text-secondary hover:text-white transition-colors">{tr.footer.about}</a>
            <a href="https://github.com/a2al/a2al" class="text-text-secondary hover:text-white transition-colors" target="_blank" rel="noopener">{tr.footer.github}</a>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
