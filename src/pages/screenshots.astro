---
import BaseLayout from '@/layouts/BaseLayout.astro'
import ScreenshotsPage from '@/components/marketing/ScreenshotsPage.astro'
import { t } from '@/i18n/strings'

const locale = 'en'
const tr = t(locale)
---

<BaseLayout
  locale={locale}
  pathKey="/screenshots"
  title={tr.meta.screenshotsTitle}
  description={tr.meta.screenshotsDescription}
>
  <ScreenshotsPage locale={locale} />
</BaseLayout>
