---
import BaseLayout from '@/layouts/BaseLayout.astro'
import Quickstart from '@/components/marketing/Quickstart.astro'
import { t } from '@/i18n/strings'

const locale = 'zh'
const tr = t(locale)
---

<BaseLayout locale={locale} pathKey="/quickstart" title={tr.meta.quickstartTitle} description={tr.meta.quickstartDescription}>
  <Quickstart locale={locale} />
</BaseLayout>
