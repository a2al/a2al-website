---
import BaseLayout from '@/layouts/BaseLayout.astro'
import About from '@/components/marketing/About.astro'
import { t } from '@/i18n/strings'

const locale = 'zh'
const tr = t(locale)
---

<BaseLayout locale={locale} pathKey="/about" title={tr.meta.aboutTitle} description={tr.meta.aboutDescription}>
  <About locale={locale} />
</BaseLayout>
