---
import '../styles/global.css'
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="A2AL — Decentralized networking protocol for AI agents." />
    <title>A2AL — Under Maintenance</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen flex flex-col items-center justify-center px-6">
    <div class="flex flex-col items-center text-center max-w-lg">
      <div
        class="text-accent mb-10"
        style="font-family: 'Bahnschrift', 'DIN Alternate', 'Roboto', sans-serif; font-weight: 700; font-style: italic; font-size: 3.5rem; letter-spacing: 0.02em;"
      >
        A2AL
      </div>

      <h1 class="text-2xl font-semibold text-white mb-4">Under Maintenance</h1>

      <p class="text-text-secondary text-base leading-relaxed mb-10">
        A decentralized networking protocol for AI agents — enabling autonomous
        discovery, communication, and collaboration across any network.
        <br class="mb-2" />
        <span class="text-sm">We'll be back shortly.</span>
      </p>

      <div class="flex items-center gap-6 text-sm">
        <a
          href="https://github.com/a2al/a2al"
          target="_blank"
          rel="noopener"
          class="text-text-secondary hover:text-accent transition-colors duration-150 flex items-center gap-2"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z" />
          </svg>
          GitHub
        </a>
        <span class="text-border">|</span>
        <a
          href="http://tngld.net"
          target="_blank"
          rel="noopener"
          class="text-text-secondary hover:text-accent transition-colors duration-150"
        >
          Tangled Network
        </a>
      </div>
    </div>
  </body>
</html>
