---
import type { Locale } from '@/i18n/config'
import { localizePath } from '@/i18n/paths'
import { t } from '@/i18n/strings'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const tr = t(locale)
const p = (path: string) => localizePath(locale, path)
const visionLines = tr.home.visionLines.filter(Boolean)
---

<!-- Hero -->
<section class="relative min-h-[85vh] flex items-center justify-center overflow-hidden pt-20">
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[500px] bg-accent/10 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="relative z-10 text-center px-6 max-w-5xl mx-auto">
    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-surface border border-border text-text-secondary text-sm font-medium mb-8">
      <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
      {tr.home.heroEyebrow}
    </div>

    <h1 class="text-5xl md:text-7xl font-bold text-white leading-tight tracking-tight mb-8">
      {tr.home.heroTitleLine1}<br />
      <span class="text-transparent bg-clip-text bg-gradient-to-r from-white to-text-secondary">{tr.home.heroTitleLine2}</span>
    </h1>
    <p class="text-lg md:text-xl text-text-secondary max-w-2xl mx-auto leading-relaxed mb-12">
      {tr.home.heroSubtitleLine1}
      <br class="hidden md:block" />
      {tr.home.heroSubtitleLine2}
    </p>
    <div class="flex flex-col sm:flex-row gap-5 justify-center items-center">
      <a href={p('/quickstart')} class="btn-primary text-base px-8 py-3.5 shadow-[0_0_40px_rgba(0,212,170,0.3)] hover:shadow-[0_0_60px_rgba(0,212,170,0.4)] transition-shadow">
        {tr.home.ctaPrimary}
      </a>
      <a href="/docs/integration/overview" class="btn-secondary text-base px-8 py-3.5 bg-surface border border-border hover:border-text-secondary rounded-md">
        {tr.home.ctaSecondary}
      </a>
    </div>
  </div>
</section>

<!-- How It Works -->
<section class="py-24 px-6 border-t border-border/50 relative">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-1/2 h-px bg-gradient-to-r from-transparent via-accent/30 to-transparent"></div>
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-20">
      <h2 class="text-3xl md:text-4xl font-semibold text-white tracking-tight mb-4">{tr.home.howTitle}</h2>
      <p class="text-text-secondary text-lg">{tr.home.howLead}</p>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      {
        tr.home.cards.map((card, idx) => (
          <div class="group card p-10 hover:bg-[#151f1c] transition-colors duration-300">
            <div class="w-12 h-12 rounded-xl bg-surface border border-border flex items-center justify-center mb-6 group-hover:border-accent/50 group-hover:text-accent transition-colors">
              {idx === 0 && (
                <svg class="w-5 h-5 text-text-secondary group-hover:text-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
                </svg>
              )}
              {idx === 1 && (
                <svg class="w-5 h-5 text-text-secondary group-hover:text-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
                </svg>
              )}
              {idx === 2 && (
                <svg class="w-5 h-5 text-text-secondary group-hover:text-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />
                </svg>
              )}
            </div>
            <h3 class="text-white font-medium text-xl mb-3">{card.title}</h3>
            <p class="text-text-secondary leading-relaxed text-sm">{card.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<!-- Vision -->
<section class="py-32 px-6 bg-surface/30 border-y border-border">
  <div class="max-w-5xl mx-auto flex flex-col md:flex-row gap-16 items-center">
    <div class="flex-1">
      <h2 class="text-3xl md:text-5xl font-medium text-white leading-tight tracking-tight mb-8">
        {tr.home.visionHeading}
      </h2>
      <div class="space-y-4 text-xl md:text-2xl text-text-secondary font-light leading-relaxed">
        {
          visionLines.map((line, i) => (
            <p class:list={{ 'text-white font-medium': i === visionLines.length - 1 }}>{line}</p>
          ))
        }
      </div>
    </div>

    <div class="flex-1 w-full flex flex-col gap-6">
      {
        tr.home.visionCards.map((item) => (
          <div class="flex gap-4 p-6 rounded-xl border border-border bg-background/50 backdrop-blur-sm">
            <div class="mt-1 w-5 h-5 shrink-0 rounded-full bg-accent/20 flex items-center justify-center">
              <div class="w-2 h-2 rounded-full bg-accent"></div>
            </div>
            <div>
              <h4 class="text-white font-medium mb-1">{item.title}</h4>
              <p class="text-text-secondary text-sm leading-relaxed">{item.desc}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<!-- Structured data -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "A2AL",
  "description": tr.meta.homeDescription,
  "url": "https://a2al.org",
  "downloadUrl": "https://github.com/a2al/a2al/releases",
  "applicationCategory": "DeveloperApplication",
  "operatingSystem": "Linux, macOS, Windows",
  "inLanguage": tr.htmlLang,
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "keywords": "AI agent, agent discovery, decentralized networking, MCP, sovereign identity, peer-to-peer, agent protocol"
})} />

<!-- CTA Cards -->
<section class="py-32 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-semibold text-white tracking-tight">{tr.home.ctaSectionTitle}</h2>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      <a href={p('/quickstart')} class="group card flex flex-col hover:border-accent/50 transition-all duration-300 block">
        <div class="text-accent text-xs font-bold tracking-widest uppercase mb-4">{tr.home.ctaCards[0].audience}</div>
        <h3 class="text-white font-semibold text-2xl mb-3 group-hover:text-accent transition-colors">{tr.home.ctaCards[0].title}</h3>
        <p class="text-text-secondary leading-relaxed mb-8 flex-1 text-sm">{tr.home.ctaCards[0].body}</p>
        <div class="text-white font-medium text-sm inline-flex items-center gap-2 group-hover:gap-3 transition-all">
          {tr.home.ctaCards[0].linkLabel} <span class="text-accent">→</span>
        </div>
      </a>

      <a href="/docs/integration/overview" class="group card flex flex-col hover:border-accent/50 transition-all duration-300 block">
        <div class="text-accent text-xs font-bold tracking-widest uppercase mb-4">{tr.home.ctaCards[1].audience}</div>
        <h3 class="text-white font-semibold text-2xl mb-3 group-hover:text-accent transition-colors">{tr.home.ctaCards[1].title}</h3>
        <p class="text-text-secondary leading-relaxed mb-8 flex-1 text-sm">{tr.home.ctaCards[1].body}</p>
        <div class="text-white font-medium text-sm inline-flex items-center gap-2 group-hover:gap-3 transition-all">
          {tr.home.ctaCards[1].linkLabel} <span class="text-accent">→</span>
        </div>
      </a>
      <a href="/docs/integration/mcp" class="group card flex flex-col hover:border-accent/50 transition-all duration-300 block">
        <div class="text-accent text-xs font-bold tracking-widest uppercase mb-4">{tr.home.ctaCards[2].audience}</div>
        <h3 class="text-white font-semibold text-2xl mb-3 group-hover:text-accent transition-colors">{tr.home.ctaCards[2].title}</h3>
        <p class="text-text-secondary leading-relaxed mb-8 flex-1 text-sm">{tr.home.ctaCards[2].body}</p>
        <div class="text-white font-medium text-sm inline-flex items-center gap-2 group-hover:gap-3 transition-all">
          {tr.home.ctaCards[2].linkLabel} <span class="text-accent">→</span>
        </div>
      </a>
    </div>
  </div>
</section>
