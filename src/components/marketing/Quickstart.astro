---
import type { Locale } from '@/i18n/config'
import { t } from '@/i18n/strings'

interface Props {
  locale: Locale
}

const { locale } = Astro.props
const tr = t(locale)

const tabActive =
  'flex-1 px-5 py-3.5 text-sm font-medium transition-all text-accent border-b-2 border-accent bg-surface/50'
const tabIdle =
  'flex-1 px-5 py-3.5 text-sm font-medium transition-all text-text-secondary hover:text-white hover:bg-surface/30 border-b-2 border-transparent'
---

<div class="relative pt-32 pb-32 px-6 overflow-hidden">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[400px] bg-accent/5 rounded-full blur-[100px] pointer-events-none"></div>

  <div class="max-w-3xl mx-auto relative z-10">
    <div class="text-center mb-24">
      <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-surface border border-border text-accent text-xs font-semibold tracking-widest uppercase mb-8">
        {tr.quickstart.eyebrow}
      </div>
      <h1 class="text-4xl md:text-6xl font-bold text-white leading-[1.1] tracking-tighter mb-6">
        {tr.quickstart.titleBefore}<span class="text-transparent bg-clip-text bg-gradient-to-r from-accent to-[#00b894]">{tr.quickstart.titleAccent}</span>
      </h1>
      <p class="text-xl md:text-2xl text-text-secondary leading-relaxed max-w-2xl mx-auto font-light">
        {tr.quickstart.subtitle}
      </p>
    </div>

    <div class="space-y-12">
      <div class="relative p-8 md:p-12 rounded-2xl bg-surface/40 border border-border/50 backdrop-blur-sm group hover:border-accent/30 transition-colors">
        <div class="absolute -top-5 left-8 md:left-12 w-10 h-10 rounded-full bg-surface border border-border text-accent font-bold flex items-center justify-center shadow-lg group-hover:shadow-[0_0_20px_rgba(0,212,170,0.3)] transition-all">1</div>

        <h2 class="text-2xl text-white font-semibold mb-8 mt-2 tracking-tight">{tr.quickstart.step1Title}</h2>

        <div class="border border-border/60 rounded-xl overflow-hidden bg-background/50 shadow-inner">
          <div class="flex border-b border-border/60 bg-surface/30">
            <button type="button" class={tabActive} data-tab="windows">{tr.quickstart.osWindows}</button>
            <button type="button" class={tabIdle} data-tab="macos">{tr.quickstart.osMac}</button>
            <button type="button" class={tabIdle} data-tab="linux">{tr.quickstart.osLinux}</button>
          </div>
          <div class="p-6 md:p-8 min-h-[220px]">
            <div data-panel="windows" class="animate-in fade-in duration-300">
              <ol class="space-y-5 text-text-secondary">
                <li class="flex items-start gap-3">
                  <span class="text-accent/60 mt-0.5">•</span>
                  <span>
                    {tr.quickstart.win1}
                    <a href="https://github.com/a2al/a2al/releases/latest" class="text-white hover:text-accent font-medium border-b border-white/20 hover:border-accent transition-colors" target="_blank" rel="noopener">a2ald_windows_amd64.zip</a>
                    {tr.quickstart.winFrom}
                  </span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-accent/60 mt-0.5">•</span>
                  <span>{tr.quickstart.win2}</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-accent/60 mt-0.5">•</span>
                  <span>
                    {tr.quickstart.win3}
                    <code class="text-accent font-mono bg-accent/10 border border-accent/20 px-1.5 py-0.5 rounded text-sm mx-1">a2ald.exe</code>
                  </span>
                </li>
              </ol>
            </div>
            <div data-panel="macos" hidden class="animate-in fade-in duration-300">
              <ol class="space-y-5 text-text-secondary">
                <li class="flex items-start gap-3">
                  <span class="text-accent/60 mt-0.5">•</span>
                  <span>
                    {tr.quickstart.mac1}
                    <a href="https://github.com/a2al/a2al/releases/latest" class="text-white hover:text-accent font-medium border-b border-white/20 hover:border-accent transition-colors" target="_blank" rel="noopener">a2ald_darwin_arm64.tar.gz</a>
                    {tr.quickstart.macFrom}
                    <span class="whitespace-nowrap">{tr.quickstart.macPlatformNote}</span>
                  </span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-accent/60 mt-0.5">•</span>
                  <span>{tr.quickstart.mac2}</span>
                </li>
              </ol>
              <div class="mt-4 bg-[#0a0f0e] border border-border/80 rounded-lg p-4 font-mono text-sm text-text-secondary flex items-center gap-3">
                <span class="text-accent/50">$</span>
                <span class="text-white">./a2ald</span>
              </div>
            </div>
            <div data-panel="linux" hidden class="animate-in fade-in duration-300">
              <div class="space-y-6 text-text-secondary">
                <div>
                  <p class="mb-3 text-sm font-medium text-white/80">{tr.quickstart.linuxDeb}</p>
                  <div class="bg-[#0a0f0e] border border-border/80 rounded-lg p-4 font-mono text-sm flex items-center gap-3 overflow-x-auto">
                    <span class="text-accent/50">$</span>
                    <span class="text-white">sudo dpkg -i a2ald_linux_amd64.deb</span>
                  </div>
                </div>
                <div>
                  <p class="mb-3 text-sm font-medium text-white/80">{tr.quickstart.linuxOther}</p>
                  <div class="bg-[#0a0f0e] border border-border/80 rounded-lg p-4 font-mono text-sm flex items-center gap-3 overflow-x-auto">
                    <span class="text-accent/50">$</span>
                    <span class="text-white">chmod +x a2ald && ./a2ald</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
        <div class="mt-6 flex items-center gap-3 text-sm text-text-secondary/80">
          <div class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></div>
          <span>
            {tr.quickstart.listeningBefore}
            <code class="font-mono text-white/80 mx-1">listening on :2121</code>
            {tr.quickstart.listeningAfter}
          </span>
        </div>
      </div>

      <div class="relative p-8 md:p-12 rounded-2xl bg-surface/40 border border-border/50 backdrop-blur-sm group hover:border-accent/30 transition-colors">
        <div class="absolute -top-5 left-8 md:left-12 w-10 h-10 rounded-full bg-surface border border-border text-accent font-bold flex items-center justify-center shadow-lg group-hover:shadow-[0_0_20px_rgba(0,212,170,0.3)] transition-all">2</div>

        <h2 class="text-2xl text-white font-semibold mb-6 mt-2 tracking-tight">{tr.quickstart.step2Title}</h2>
        <p class="text-text-secondary text-lg mb-6 font-light">{tr.quickstart.step2Lead}</p>

        <a href="http://localhost:2121" target="_blank" rel="noopener" class="group/link block bg-background/80 border border-border/80 rounded-xl p-6 font-mono text-xl hover:border-accent/50 transition-all flex items-center justify-between">
          <span class="text-white group-hover/link:text-accent transition-colors">http://localhost:2121</span>
          <svg class="w-5 h-5 text-text-secondary/50 group-hover/link:text-accent transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>

      <div class="relative p-8 md:p-12 rounded-2xl bg-surface/40 border border-border/50 backdrop-blur-sm group hover:border-accent/30 transition-colors">
        <div class="absolute -top-5 left-8 md:left-12 w-10 h-10 rounded-full bg-surface border border-border text-accent font-bold flex items-center justify-center shadow-lg group-hover:shadow-[0_0_20px_rgba(0,212,170,0.3)] transition-all">3</div>

        <h2 class="text-2xl text-white font-semibold mb-6 mt-2 tracking-tight">{tr.quickstart.step3Title}</h2>

        <div class="space-y-6 text-lg text-text-secondary font-light leading-relaxed">
          <p>
            {tr.quickstart.step3P1Before}
            <strong class="text-white font-medium">{tr.quickstart.step3P1Strong}</strong>
            {tr.quickstart.step3P1After}
          </p>

          <div class="flex gap-4 p-5 rounded-xl border border-amber-500/20 bg-amber-500/5 items-start">
            <svg class="w-6 h-6 text-amber-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
            <p class="text-sm text-amber-500/90 leading-relaxed">
              <strong class="text-amber-400 font-semibold">{tr.quickstart.warnTitle}</strong>{' '}
              {tr.quickstart.warnBody}
            </p>
          </div>

          <p>
            {tr.quickstart.step3P2a}
            <span class="inline-flex items-center gap-1.5 px-2 py-0.5 rounded bg-accent/10 text-accent text-sm font-medium border border-accent/20 mx-1">
              <span class="w-1.5 h-1.5 rounded-full bg-accent"></span>
              {tr.quickstart.publishedBadge}
            </span>
            {tr.quickstart.step3P2b}
          </p>
        </div>
      </div>

      <!-- Success Message -->
      <div class="flex items-center justify-center py-6">
        <div class="inline-flex items-center gap-3 px-8 py-4 rounded-full bg-accent/5 border border-accent/20 text-accent text-lg font-medium shadow-[0_0_30px_rgba(0,212,170,0.1)] backdrop-blur-sm relative">
          <div class="absolute inset-0 rounded-full border border-accent/30 animate-pulse"></div>
          <div class="w-7 h-7 rounded-full bg-accent/20 flex items-center justify-center shrink-0">
            <svg class="w-4 h-4 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <span>{tr.quickstart.successMessage}</span>
        </div>
      </div>
    </div>

    <div class="mt-24 p-10 rounded-2xl bg-gradient-to-br from-surface/80 to-background border border-border relative overflow-hidden">
      <div class="absolute right-0 top-0 w-64 h-64 bg-accent/5 rounded-full blur-[80px] pointer-events-none"></div>
      <div class="relative z-10">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-accent/10 border border-accent/20 text-accent text-xs font-semibold tracking-widest uppercase mb-6">
          {tr.quickstart.mcpEyebrow}
        </div>
        <h3 class="text-2xl text-white font-semibold mb-4 tracking-tight">{tr.quickstart.mcpTitle}</h3>
        <p class="text-text-secondary text-lg font-light leading-relaxed mb-8 max-w-2xl">
          {tr.quickstart.mcpBodyBefore}
          <strong class="text-white font-medium">{tr.quickstart.mcpBodyStrong}</strong>
          {tr.quickstart.mcpBodyAfter}
          <em class="text-white/80 block mt-4 p-4 bg-[#0a0f0e] border border-border/50 rounded-lg not-italic font-mono text-sm">{tr.quickstart.mcpQuote}</em>
        </p>

        <a href="/docs/integration/mcp" class="inline-flex items-center gap-2 text-white font-medium text-sm group">
          <span class="border-b border-white/30 group-hover:border-accent transition-colors pb-0.5">{tr.quickstart.mcpLink}</span>
          <span class="text-accent group-hover:translate-x-1 transition-transform">→</span>
        </a>
      </div>
    </div>

    <div class="mt-32 pt-16 border-t border-border/50">
      <h2 class="text-2xl text-white font-semibold tracking-tight mb-8 text-center">{tr.quickstart.nextTitle}</h2>
      <div class="grid sm:grid-cols-2 gap-6">
        {
          tr.quickstart.nextSteps.map((step) => (
            <a href={step.href} class="group p-6 rounded-xl border border-border/50 bg-surface/30 hover:bg-surface hover:border-accent/40 transition-all flex flex-col justify-center text-center">
              <div class="text-accent text-xs font-bold tracking-widest uppercase mb-3">{step.eyebrow}</div>
              <div class="text-white font-semibold text-lg mb-2 group-hover:text-accent transition-colors">{step.title}</div>
              <div class="text-text-secondary text-sm font-light">{step.desc}</div>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</div>

<script>
  const tabs = document.querySelectorAll('[data-tab]')
  const panels = document.querySelectorAll('[data-panel]')
  const tabActive =
    'flex-1 px-5 py-3.5 text-sm font-medium transition-all text-accent border-b-2 border-accent bg-surface/50'
  const tabIdle =
    'flex-1 px-5 py-3.5 text-sm font-medium transition-all text-text-secondary hover:text-white hover:bg-surface/30 border-b-2 border-transparent'

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const target = (tab as HTMLElement).dataset.tab
      tabs.forEach((t) => {
        const isTarget = (t as HTMLElement).dataset.tab === target
        t.className = isTarget ? tabActive : tabIdle
      })
      panels.forEach((p) => {
        if ((p as HTMLElement).dataset.panel === target) {
          p.removeAttribute('hidden')
          void (p as HTMLElement).offsetWidth
        } else {
          p.setAttribute('hidden', '')
        }
      })
    })
  })
</script>
