---
import type { Locale } from '@/i18n/config'
import { locales } from '@/i18n/config'
import { localizePath } from '@/i18n/paths'
import { strings } from '@/i18n/strings'

interface Props {
  locale: Locale
  pathKey: '/' | '/about' | '/quickstart'
}

const { locale, pathKey } = Astro.props
const t = strings[locale]
const labels: Record<Locale, string> = {
  en: t.langSwitcher.en,
  zh: t.langSwitcher.zh,
  ja: t.langSwitcher.ja,
}
---

<div class="flex items-center gap-1 rounded-md border border-border/60 bg-surface/40 p-0.5 text-xs font-medium">
  {
    locales.map((loc) => (
      <a
        href={localizePath(loc, pathKey)}
        class:list={[
          'rounded px-2 py-1 transition-colors',
          loc === locale
            ? 'bg-accent/15 text-accent'
            : 'text-text-secondary hover:text-white',
        ]}
        hreflang={strings[loc].htmlLang}
      >
        {labels[loc]}
      </a>
    ))
  }
</div>
